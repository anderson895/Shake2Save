// Copy these rules to your Firebase Console > Firestore > Rules
// Firebase Console: https://console.firebase.google.com/project/shak2save/firestore/rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Emergency Contacts - only the owner can read/write
    match /emergencyContacts/{contactId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // Emergency Alerts - owner can create/read, anyone authenticated can read pending (for responders)
    match /emergencyAlerts/{alertId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
